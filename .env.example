# --- GlowGPT Configuration Example ---
# Rename this file to '.env' and modify as needed.

MODEL_NAME=qwen:1.8b
OLLAMA_HOST=http://localhost:11434
APP_HOST=0.0.0.0
APP_PORT=8000

# Context window: Max tokens the model remembers (e.g., 2048, 4096, 8192)
# Larger context consumes more RAM.
CONTEXT_WINDOW=4096
